# ─── Database ────────────────────────────────────────────────────────────────
# Same PostgreSQL instance as the Django backend (DIS writes, Django reads)
DATABASE_URL=postgresql://user:password@localhost:5432/careerscoper

# ─── External Job APIs ────────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_API_KEY=
ADZUNA_COUNTRY=us

JOOBLE_API_KEY=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_SUBREDDITS=forhire,remotejobs,cscareerquestionsjobs

EVENTBRITE_API_KEY=

# ─── Web Crawling / Discovery ─────────────────────────────────────────────────
# Firecrawl-compatible crawler (self-hosted or managed)
CRAWLER_BASE_URL=http://localhost:7071
CRAWLER_API_KEY=
CRAWLER_HTTP_TIMEOUT=20

TAVILY_API_KEY=

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

GEMINI_API_KEY=

# AI provider preference for extraction tasks
AI_PRIMARY=gemini
AI_FALLBACK=openrouter

# ─── Salary API (optional) ────────────────────────────────────────────────────
SALARY_API_BASE_URL=
SALARY_API_KEY=

# ─── News ─────────────────────────────────────────────────────────────────────
INDUSTRY_DIVE_API_KEY=
INDUSTRY_DIVE_BASE_URL=https://www.industrydive.com

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Override default intervals (in minutes/hours) if needed
ADZUNA_INTERVAL_MINUTES=10
JOOBLE_INTERVAL_MINUTES=10
REDDIT_INTERVAL_MINUTES=10
EVENTBRITE_INTERVAL_MINUTES=10
ATS_INTERVAL_HOURS=12
COMPANY_NEWS_INTERVAL_HOURS=6
RSS_NEWS_INTERVAL_MINUTES=20
INDUSTRY_DIVE_INTERVAL_MINUTES=10
COMPANY_ENRICHMENT_INTERVAL_HOURS=24
COMPANY_BACKFILL_INTERVAL_HOURS=1
